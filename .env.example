# База данных PostgreSQL (используется в docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=secure_museum_password_2026
POSTGRES_DB=museum
DATABASE_URL=postgresql://user:secure_museum_password_2026@db/museum

# Безопасность и авторизация (JWT)
JWT_SECRET_KEY=my_super_secret_jwt_key_for_museum_diploma_project
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Учётные данные администратора по умолчанию (создаётся при первом запуске)
ADMIN_DEFAULT_LOGIN=admin
ADMIN_DEFAULT_PASSWORD=password123
ADMIN_DEFAULT_EMAIL=admin@museum.ru

# CORS разрешения (адреса клиентов для подключения к бэкенду)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost,capacitor://localhost

# Интеграция с локальной нейросетью Ollama (контейнер ollama в docker-compose)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=gemma2:9b
