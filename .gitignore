# ── Артефакты PowerShell: в cmd "nul" — это чёрная дыра, а в PowerShell
#    команда вида "cmd > nul" создаёт реальный файл с именем "nul".
#    Это мусор, он не должен попадать в репозиторий.
nul
**/nul

# ── Дампы БД (бэкапы pg_dump). init.sql ниже явно исключён из игнорирования.
dump_full_*.sql
*.dump
*.backup

# ── Python (бэкенд) ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example

# ── Node.js (моб. приложение, админ-панель) ──────────────────────────
node_modules/
dist/
build/
*.log
npm-debug.log*

# ── IDE / ОС ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
